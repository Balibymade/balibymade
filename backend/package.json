{
  "name": "balibymade-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "dotenv -e .env -- keystone dev",
    "build": "MALLOC_ARENA_MAX=2 NODE_OPTIONS=--max-old-space-size=2048 keystone build",
    "migrate": "node scripts/migrate-safe.js",
    "start": "MALLOC_ARENA_MAX=2 keystone start",
    "start:prod": "npm run migrate && npm run start",
    "seed": "dotenv -e .env -- ts-node --transpile-only seed.ts",
    "seed:manuals": "dotenv -e .env -- ts-node --transpile-only seed-manuals.ts"
  },
  "dependencies": {
    "@keystone-6/auth": "^8.0.0",
    "@keystone-6/core": "^6.0.0",
    "@keystone-6/fields-document": "^9.0.0",
    "dotenv": "^17.2.3",
    "express-rate-limit": "^8.3.1",
    "typescript": "^5.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.35",
    "dotenv-cli": "^11.0.0",
    "ts-node": "^10.9.2"
  },
  "overrides": {
    "slate-react": "0.110.2"
  }
}
