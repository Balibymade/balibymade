# Base de datos
# Local: postgresql://keystone:keystonepassword@localhost:5435/balibymade
# Producción: pooler de Supabase
DATABASE_URL=

# Auth (mínimo 64 caracteres aleatorios — generar con: openssl rand -hex 32)
SESSION_SECRET=

# Cloudflare R2 (imágenes, S3-compatible)
R2_BUCKET_NAME=balibymade-media
R2_S3_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_URL=
