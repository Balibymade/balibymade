# Base de datos
# Local: postgresql://keystone:keystonepassword@localhost:5435/balibymade
# Producción: pooler de Supabase
DATABASE_URL=

# Auth (mínimo 64 caracteres aleatorios — generar con: openssl rand -hex 32)
SESSION_SECRET=

# Supabase Storage (imágenes)
SUPABASE_STORAGE_BUCKET=balibymade-media
SUPABASE_S3_REGION=eu-west-1
SUPABASE_S3_ENDPOINT=
SUPABASE_S3_ACCESS_KEY_ID=
SUPABASE_S3_SECRET_ACCESS_KEY=
# Solo el dominio base: https://xxx.supabase.co (sin path)
SUPABASE_STORAGE_PUBLIC_URL=
